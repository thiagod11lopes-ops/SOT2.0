# Copie para `.env` na raiz (não commite `.env`).
# Firebase Console → Definições do projeto → Suas apps → Web → copiar configuração.

# Obrigatórios para sincronizar **saídas** (Firestore) entre dispositivos:
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# Opcionais (recomendados no objeto do Firebase):
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Se vazio, o SOT usa só IndexedDB neste navegador (comportamento anterior).
