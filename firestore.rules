rules_version = '2';

// Implementar no Firebase Console → Firestore → Regras → Publicar.
// Autenticação anónima deve estar ativa (Authentication → Sign-in method → Anonymous).

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function versionValue(data) {
      return ('version' in data) ? data.version : 0;
    }

    function updatedAtValue(data) {
      return ('updatedAt' in data) ? data.updatedAt : 0;
    }

    function validVersionForCreate() {
      return ('version' in request.resource.data) &&
        (request.resource.data.version is int) &&
        (request.resource.data.version >= 1);
    }

    function validVersionAdvanceForUpdate() {
      return ('version' in request.resource.data) &&
        (request.resource.data.version is int) &&
        (request.resource.data.version == versionValue(resource.data) + 1);
    }

    function validUpdatedAtMonotonic() {
      return ('updatedAt' in request.resource.data) &&
        (request.resource.data.updatedAt is int) &&
        (request.resource.data.updatedAt >= updatedAtValue(resource.data));
    }

    match /departures/{departureId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && validVersionForCreate();
      allow update: if isSignedIn() && validVersionAdvanceForUpdate() && validUpdatedAtMonotonic();
      allow delete: if isSignedIn();
    }

    match /sot_state/{docId} {
      allow read, write: if isSignedIn();
    }

    /** Localização ativa por viatura (escrita só via Cloud Function Admin). */
    match /driver_active_locations/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    /**
     * Atribuição motorista→placa actual.
     * Escrita pelo SOT mobile no "Iniciar Saída" para a Cloud Function `postOwntracksLocation`
     * (iPhones a usarem OwnTracks) saber em que placa registar a posição. Limpa no "Finalizar".
     */
    match /motorista_active_assignments/{motoristaSlug} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    /**
     * Localização em tempo real do utilizador autenticado (escrita directa do
     * cliente, sem Cloud Function). Cada utilizador só pode escrever no
     * documento que tem o seu próprio uid; qualquer utilizador autenticado pode
     * ler (para o mapa partilhado). Usado pelo `LiveTrackingMap`.
     */
    match /user_locations/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    /** Subscrições push mobile — leitura para métricas do Painel de Controle. */
    match /sot_mobile_push_subscriptions/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
